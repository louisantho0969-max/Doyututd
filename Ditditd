-- INSTALLATEUR COMPLET PANEL TP - UN SEUL FICHIER
-- =============================================

RegisterCommand('installtp', function(source)
    if source ~= 0 then
        print("^1[TP-PANEL] ^7Utilise cette commande en console serveur ou avec un admin.")
        return
    end

    local resourceName = "tp-panel"
    local basePath = GetResourcePath(resourceName)

    if basePath == "" then
        print("^2[TP-PANEL] Création du dossier " .. resourceName)
        os.execute("mkdir " .. resourceName)
        basePath = GetResourcePath(resourceName)
    end

    -- Création des dossiers
    os.execute("mkdir -p " .. basePath .. "/html")

    -- ====================== fxmanifest.lua ======================
    local fx = [[
fx_version 'cerulean'
game 'gta5'

author 'Grok'
description 'Panel Téléportation Joueurs'
version '1.0.0'

ui_page 'html/index.html'

files {
    'html/index.html',
    'html/script.js',
    'html/style.css'
}

client_script 'client.lua'
server_script 'server.lua'

lua54 'yes'
]]
    SaveResourceFile(resourceName, "fxmanifest.lua", fx, -1)

    -- ====================== client.lua ======================
    local client = [[
local selectedPlayer = nil

RegisterCommand('tppanel', function()
    if not IsPlayerAdmin() then 
        TriggerEvent('esx:showNotification', '~r~Tu n\'as pas les droits.')
        return 
    end
    SendNUIMessage({ action = "open" })
    SetNuiFocus(true, true)
end, false)

function IsPlayerAdmin()
    return true -- Change ici selon ton framework (ESX/QBCore)
end

RegisterNUICallback('close', function(data, cb)
    SetNuiFocus(false, false)
    cb('ok')
end)

RegisterNUICallback('tpToPlayer', function(data, cb)
    if not selectedPlayer then return end
    TriggerServerEvent('tp-panel:tpToPlayer', selectedPlayer)
    cb('ok')
end)

RegisterNUICallback('playerTpToMe', function(data, cb)
    if not selectedPlayer then return end
    TriggerServerEvent('tp-panel:playerTpToMe', selectedPlayer)
    cb('ok')
end)

RegisterNetEvent('tp-panel:updatePlayers')
AddEventHandler('tp-panel:updatePlayers', function(players)
    SendNUIMessage({ action = "updatePlayers", players = players })
end)
]]
    SaveResourceFile(resourceName, "client.lua", client, -1)

    -- ====================== server.lua ======================
    local server = [[
local playersList = {}

CreateThread(function()
    while true do
        playersList = {}
        for _, playerId in ipairs(GetPlayers()) do
            table.insert(playersList, {
                serverId = tonumber(playerId),
                name = GetPlayerName(playerId)
            })
        end
        TriggerClientEvent('tp-panel:updatePlayers', -1, playersList)
        Wait(5000)
    end
end)

RegisterServerEvent('tp-panel:tpToPlayer')
AddEventHandler('tp-panel:tpToPlayer', function(targetId)
    local src = source
    if not IsPlayerAdmin(src) then return end

    local ped = GetPlayerPed(src)
    local targetPed = GetPlayerPed(targetId)
    if DoesEntityExist(targetPed) then
        local coords = GetEntityCoords(targetPed)
        SetEntityCoords(ped, coords.x, coords.y, coords.z + 1.0, false, false, false, true)
    end
end)

RegisterServerEvent('tp-panel:playerTpToMe')
AddEventHandler('tp-panel:playerTpToMe', function(targetId)
    local src = source
    if not IsPlayerAdmin(src) then return end

    local coords = GetEntityCoords(GetPlayerPed(src))
    TriggerClientEvent('tp-panel:forceTp', targetId, coords)
end)

RegisterNetEvent('tp-panel:forceTp')
AddEventHandler('tp-panel:forceTp', function(coords)
    local ped = PlayerPedId()
    SetEntityCoords(ped, coords.x, coords.y, coords.z + 1.0, false, false, false, true)
end)

function IsPlayerAdmin(src)
    return true -- Change ici selon ton framework
end
]]
    SaveResourceFile(resourceName, "server.lua", server, -1)

    -- ====================== html/index.html ======================
    local html = [[
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel TP</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>Panel Téléportation</h1>
        <div class="player-list" id="playerList"></div>
        <div class="buttons">
            <button id="btnTpTo">Se téléporter à lui</button>
            <button id="btnTpMe">Il se téléporte à moi</button>
        </div>
        <button id="closeBtn">Fermer</button>
    </div>
    <script src="script.js"></script>
</body>
</html>
]]
    SaveResourceFile(resourceName, "html/index.html", html, -1)

    -- ====================== html/style.css ======================
