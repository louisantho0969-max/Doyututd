    SaveResourceFile(resourceName, "html/style.css", css, -1)

    -- ====================== html/script.js ======================
    local js = [[
let selectedId = null;

window.addEventListener('message', function(event) {
    if (event.data.action === "open") {
        document.body.style.display = 'flex';
    }
    if (event.data.action === "updatePlayers") {
        updatePlayerList(event.data.players);
    }
});

function updatePlayerList(players) {
    const container = document.getElementById('playerList');
    container.innerHTML = '';
    players.forEach(player => {
        const div = document.createElement('div');
        div.className = 'player-item';
        div.textContent = `${player.name} (${player.serverId})`;
        div.dataset.id = player.serverId;
        div.onclick = () => {
            document.querySelectorAll('.player-item').forEach(e => e.classList.remove('selected'));
            div.classList.add('selected');
            selectedId = parseInt(div.dataset.id);
        };
        container.appendChild(div);
    });
}

document.getElementById('btnTpTo').onclick = () => {
    if (selectedId) fetch(`https://${GetParentResourceName()}/tpToPlayer`, {
        method: 'POST', body: JSON.stringify({serverId: selectedId})
    });
};

document.getElementById('btnTpMe').onclick = () => {
    if (selectedId) fetch(`https://${GetParentResourceName()}/playerTpToMe`, {
        method: 'POST', body: JSON.stringify({serverId: selectedId})
    });
};

document.getElementById('closeBtn').onclick = () => {
    fetch(`https://${GetParentResourceName()}/close`, {method: 'POST'});
    document.body.style.display = 'none';
};

document.addEventListener('keydown', e => {
    if (e.key === "Escape") {
        fetch(`https://${GetParentResourceName()}/close`, {method: 'POST'});
        document.body.style.display = 'none';
    }
});
]]
    SaveResourceFile(resourceName, "html/script.js", js, -1)

    print("^2[TP-PANEL] ^7Installation terminée avec succès !")
    print("^3Ajoute ceci dans ton server.cfg : ^7ensure tp-panel")
    print("^5Tape ^7/tppanel ^5en jeu pour ouvrir le panel.")

end, true)
